    <!-- Critical above-the-fold CSS inlined -->
    <style>
      /* Reset */
      *,::before,::after{box-sizing:border-box;border-width:0;border-style:solid}
      html{-webkit-text-size-adjust:100%;line-height:1.5;-moz-tab-size:4;-o-tab-size:4;tab-size:4}
      body{margin:0;font-family:'Inter',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;-webkit-font-smoothing:antialiased;line-height:inherit}
      #root{min-height:100vh}
      img,video{display:block;max-width:100%}

      /* Hero shell layout */
      .owrx-shell{position:relative;min-height:100vh;background:#0B7A8C;display:flex;align-items:center;justify-content:center;overflow:hidden}
      .owrx-shell-inner{position:relative;z-index:10;width:100%;max-width:1280px;margin:0 auto;padding:96px 40px 80px;display:flex;flex-direction:column;align-items:center;text-align:center}
      .owrx-h1{font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:clamp(2rem,6vw,4.5rem);font-weight:700;color:#fff;line-height:1.15;margin:0 0 24px;max-width:900px;opacity:1;letter-spacing:-0.01em}
      .owrx-accent{color:#E8A923}
      .owrx-sub{color:rgba(255,255,255,0.85);font-size:clamp(1rem,2vw,1.2rem);max-width:600px;margin:0 0 40px;line-height:1.65;font-weight:300}
      .owrx-cta{background:#E8A923;color:#fff;font-weight:600;padding:18px 48px;border-radius:9999px;text-decoration:none;font-size:1rem;display:inline-block;white-space:nowrap;font-family:inherit}

      /* Tailwind critical utilities */
      .relative{position:relative}.absolute{position:absolute}.inset-0{inset:0}
      .overflow-hidden{overflow:hidden}.min-h-screen{min-height:100vh}
      .flex{display:flex}.items-center{align-items:center}.justify-center{justify-content:center}
      .w-full{width:100%}.h-full{height:100%}
      .object-cover{-o-object-fit:cover;object-fit:cover}.object-top{-o-object-position:top;object-position:top}
      .z-10{z-index:10}.z-50{z-index:50}.fixed{position:fixed}
      .top-0{top:0}.left-0{left:0}.right-0{right:0}
      .text-white{color:#fff}.font-bold{font-weight:700}.text-center{text-align:center}
      .bg-\[\#0B7A8C\]{background-color:#0B7A8C}

      /* Scroll animations */
      .anim-fade-up{opacity:0.01;transform:translateY(28px);transition:opacity .6s ease,transform .6s ease}
      .anim-fade-up.is-visible{opacity:1;transform:translateY(0)}
      .anim-fade-in{opacity:0.01;transition:opacity .7s ease}
      .anim-fade-in.is-visible{opacity:1}
      .anim-slide-left{opacity:0.01;transform:translateX(-32px);transition:opacity .65s ease,transform .65s ease}
      .anim-slide-left.is-visible{opacity:1;transform:translateX(0)}
      .anim-slide-right{opacity:0.01;transform:translateX(32px);transition:opacity .65s ease,transform .65s ease}
      .anim-slide-right.is-visible{opacity:1;transform:translateX(0)}
      .anim-delay-100{transition-delay:100ms}.anim-delay-200{transition-delay:200ms}
      .anim-delay-300{transition-delay:300ms}.anim-delay-400{transition-delay:400ms}
      .anim-delay-500{transition-delay:500ms}

      @media (prefers-reduced-motion:no-preference){html{scroll-behavior:smooth}}

      /* owrx-body-content: per-route static content slot (hidden when empty) */
      .owrx-body-content:empty{display:none}
      .owrx-body-content{width:100%;max-width:900px;margin:48px auto 0;padding:0 24px;text-align:left;color:rgba(255,255,255,0.9)}
      .owrx-body-content h2{font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:clamp(1.25rem,3vw,1.75rem);font-weight:700;color:#fff;margin:0 0 12px;line-height:1.2}
      .owrx-body-content p{font-size:0.975rem;line-height:1.7;color:rgba(255,255,255,0.82);margin:0 0 16px}
      .owrx-body-content .owrx-faq{border-top:1px solid rgba(255,255,255,0.18);margin-top:32px;padding-top:24px}
      .owrx-body-content .owrx-faq-item{padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.12)}
      .owrx-body-content .owrx-faq-item dt{font-weight:600;font-size:0.975rem;color:#fff;margin:0 0 6px}
      .owrx-body-content .owrx-faq-item dd{margin:0;font-size:0.9rem;line-height:1.65;color:rgba(255,255,255,0.78)}
      .owrx-body-content .owrx-links{margin-top:32px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.18)}
      .owrx-body-content .owrx-links h2{margin-bottom:14px}
      .owrx-body-content .owrx-links ul{list-style:none;padding:0;margin:0;display:flex;flex-wrap:wrap;gap:10px}
      .owrx-body-content .owrx-links li{}
      .owrx-body-content .owrx-links a{display:inline-block;background:rgba(255,255,255,0.12);color:#fff;text-decoration:none;padding:8px 16px;border-radius:9999px;font-size:0.875rem;font-weight:500;border:1px solid rgba(255,255,255,0.22)}
