    <!-- Ultra-early IAB error guard — runs before any third-party scripts load so
         GTM, Clarity, and Meta Pixel crashes are swallowed before they can break the page. -->
    <script type="a5d65b8ac30a3d8468d52e1b-text/javascript">
    (function() {
      var iabRe = /FBAN|FBAV|Instagram|FB_IAB|FB4A|FBIOS|BytedanceWebview|musical_ly|TikTok|LinkedInApp|Snapchat|Pinterest/;
      var crashRe = /enabledidusertypeonkeyboardlogging|java object is gone|script error\.|java object|invoking|bridge|webview|cannot read property|undefined is not|null is not/i;
      function inIAB() {
        try { return iabRe.test(navigator.userAgent || ''); } catch (_e) { return false; }
      }
      function isCrash(msg) {
        try { msg = String(msg || '').toLowerCase(); } catch (_e) { msg = ''; }
        return crashRe.test(msg) || inIAB();
      }
      function swallow(e) {
        var msg = '';
        try { msg = (e && e.message) || (e && e.reason) || ''; } catch (_e) { msg = ''; }
        if (!isCrash(msg)) return;
        try { if (e.preventDefault) e.preventDefault(); } catch (_e) {}
        try { if (e.stopPropagation) e.stopPropagation(); } catch (_e) {}
        try { if (e.stopImmediatePropagation) e.stopImmediatePropagation(); } catch (_e) {}
      }
      try { window.addEventListener('error', swallow, true); } catch (_e) {}
      try { window.addEventListener('unhandledrejection', swallow, true); } catch (_e) {}
    })();
    </script>
    <!-- Google Tag Manager — deferred until first user interaction so it never
         blocks LCP, FID, or INP. dataLayer is stubbed immediately so any early
         pushes (e.g. from gtag) are queued and replayed once GTM loads. -->
    <script type="a5d65b8ac30a3d8468d52e1b-text/javascript">
      window.dataLayer = window.dataLayer || [];
      (function() {
        var _gtmLoaded = false;
        function loadGTM() {
          if (_gtmLoaded) return;
          _gtmLoaded = true;
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-5WT6DTMH');
        }
        // Fire on first scroll, click, touch, or keydown
        var _gtmEvents = ['scroll','click','touchstart','keydown','mousemove'];
        function _gtmInteraction() {
          loadGTM();
          _gtmEvents.forEach(function(e){ window.removeEventListener(e, _gtmInteraction, {passive:true}); });
        }
        _gtmEvents.forEach(function(e){ window.addEventListener(e, _gtmInteraction, {passive:true}); });
        // Fallback: load after 6s even with no interaction
        setTimeout(loadGTM, 6000);
      })();
    </script>
    <!-- End Google Tag Manager -->
    <!-- Google tag (gtag.js) — direct install for GA4 property G-SQC07LFLPR
         Ensures the tag loads on every route, including the static shell,
         so Google Tag Assistant detects it even before React hydrates. -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <script defer src="https://www.googletagmanager.com/gtag/js?id=G-SQC07LFLPR" type="a5d65b8ac30a3d8468d52e1b-text/javascript"></script>
    <script defer type="a5d65b8ac30a3d8468d52e1b-text/javascript">
      window.addEventListener("DOMContentLoaded", function() {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        // Default consent: analytics granted (first-party), ads denied until user opts in.
        // This is required by Google for EEA/UK traffic — without it, conversion
        // measurement may be throttled or blocked for ad campaigns.
        gtag('consent', 'default', {
          'analytics_storage': 'granted',
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'wait_for_update': 2000,
        });

        gtag('config', 'G-SQC07LFLPR');
      });
    </script>
