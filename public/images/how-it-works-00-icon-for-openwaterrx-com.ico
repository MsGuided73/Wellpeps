            window.clarity("set", "maskTextSelector", "input, textarea, [data-sensitive], [type='password'], [type='email'], [name*='ssn'], [name*='card']");
            window.clarity("set", "maskAttribute", ["value", "placeholder", "title"]);
          } catch (_e) {
            // Clarity may fail in stripped WebViews — silently ignore
          }
        }
        function scheduleClarity() {
          if (window.requestIdleCallback) {
            requestIdleCallback(initClarity, { timeout: 4000 });
          } else {
            setTimeout(initClarity, 2000);
          }
