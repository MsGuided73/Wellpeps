    <!-- Meta Pixel Code — deferred until first user interaction to avoid blocking LCP/FID -->
    <script type="a5d65b8ac30a3d8468d52e1b-text/javascript">
      (function() {
        // Stub fbq immediately so any early calls are queued, not lost
        if (!window.fbq) {
          var n = window.fbq = function() {
            n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
          };
          if (!window._fbq) window._fbq = n;
          n.push = n; n.loaded = true; n.version = '2.0'; n.queue = [];
        }
        fbq('init', '1239219944716616');

        function loadPixel() {
          if (window._fbPixelLoaded) return;
          window._fbPixelLoaded = true;
          var t = document.createElement('script');
          t.async = true;
          t.src = 'https://connect.facebook.net/en_US/fbevents.js';
          document.head.appendChild(t);
          fbq('track', 'PageView');
        }

        // Fire on first scroll, click, or touch — whichever comes first
        var events = ['scroll', 'click', 'touchstart', 'keydown'];
        function onInteraction() {
          loadPixel();
          events.forEach(function(e) { window.removeEventListener(e, onInteraction, { passive: true }); });
        }
        events.forEach(function(e) { window.addEventListener(e, onInteraction, { passive: true }); });

        // Fallback: load after 5s even with no interaction (covers bots, slow users)
        setTimeout(loadPixel, 5000);
      })();
    </script>
